SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
PORT=3001
CLIENT_URL=http://localhost:5173
TRUST_PROXY=false

# 32-byte hex key for AES-256-GCM encryption of Microsoft auth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Optional emergency fallback: allow admin API key auth in addition to Supabase JWT auth.
# Leave disabled in production once user auth is wired.
ALLOW_ADMIN_API_KEY_FALLBACK=false

# 32+ char admin API key (only used when ALLOW_ADMIN_API_KEY_FALLBACK=true)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_API_KEY=

# UUID of a real auth.users row to impersonate when using admin key fallback.
ADMIN_FALLBACK_USER_ID=

# Webhook listener for GitHub auto-deploy
WEBHOOK_SECRET=
WEBHOOK_PORT=9000
