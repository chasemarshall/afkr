SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
PORT=3001
CLIENT_URL=http://localhost:5173
TRUST_PROXY=false

# 32-byte hex key for AES-256-GCM encryption of Microsoft auth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Azure AD app client ID for Microsoft/Minecraft auth (device code flow).
# Register at https://portal.azure.com → App registrations.
# Enable "Allow public client flows" and add XboxLive.signin API permission.
AZURE_CLIENT_ID=

# Webhook listener for GitHub auto-deploy
WEBHOOK_SECRET=
WEBHOOK_PORT=9000
